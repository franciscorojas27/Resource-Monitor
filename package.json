{
  "name": "dotnet-monitor-grafic",
  "displayName": ".NET Recourse Monitor",
  "description": "Una extensión ligera y sin dependencias para monitorear en tiempo real el CPU, Memoria, Disco y Red de tus aplicaciones .NET directamente en VS Code.",
  "version": "0.0.1",
  "author": "Francisco Rojas",
  "license": "MIT",
  "icon": "media/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/franciscorojas27/Resource-Monitor"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Visualization",
    "Debuggers",
    "Programming Languages"
  ],
  "activationEvents": [
    "onDebug"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dotnet-monitor-container",
          "title": ".NET Monitor",
          "icon": "$(pulse)"
        }
      ]
    },
    "views": {
      "dotnet-monitor-container": [
        {
          "type": "webview",
          "id": "dotnet-monitor-view",
          "icon": "$(pulse)",
          "name": "Métricas de Rendimiento"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/pidusage": "^2.0.5",
    "@types/ps-list": "^6.2.1",
    "@types/systeminformation": "^3.54.1",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "pidusage": "^4.0.1",
    "ps-list": "^9.0.0",
    "systeminformation": "^5.31.4"
  }
}